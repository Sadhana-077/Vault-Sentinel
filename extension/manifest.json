{
  "manifest_version": 3,
  "name": "VaultSentinel",
  "description": "Real-time crypto exchange solvency monitoring powered by Chainlink CRE",
  "version": "1.0.0",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "VaultSentinel - Exchange Solvency Monitor"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.chainlink.com/*",
    "https://api.coingecko.com/*",
    "https://api.etherscan.io/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
