NODE_ENV=development
PORT=3001

# RPC Endpoints
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/demo
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/demo
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/demo
OPTIMISM_RPC=https://opt-mainnet.g.alchemy.com/v2/demo

# Cache Settings (in minutes)
CACHE_TTL=15

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# CRE Scheduler Configuration
CRE_SCHEDULER_ENABLED=true
CRE_CRON_EXPRESSION=*/5 * * * *
CRE_CONCURRENCY=3
CRE_TIMEZONE=UTC
